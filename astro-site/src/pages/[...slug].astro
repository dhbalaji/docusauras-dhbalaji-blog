---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSitePages, getSitePageUrl } from '../lib/content';

export async function getStaticPaths() {
  const pages = await getSitePages();
  return pages.map((entry) => ({
    params: {
      slug: getSitePageUrl(entry).replace(/^\//, ''),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const routeSegments = entry.data.route.split('/').filter(Boolean);
const sectionLabel = routeSegments[0]?.replace(/-/g, ' ') ?? 'Page';
const routeLabel = entry.data.route;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  path={entry.data.route}
  image={entry.data.image}
  keywords={entry.data.keywords ?? []}
>
  <section class="grid gap-8 lg:grid-cols-[15rem_minmax(0,1fr)]">
    <aside class="rounded border border-white/80 bg-white/75 p-6 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Section</p>
      <p class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink-950">{sectionLabel}</p>
      <p class="mt-4 text-sm leading-7 text-ink-600">
        This page is part of the broader site content migrated into Astro with a simpler, documentation-first reading
        experience.
      </p>
      <div class="mt-6 border-t border-ink-200 pt-4">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-ink-500">Path</p>
        <p class="mt-2 break-all font-mono text-xs text-ink-600">{routeLabel}</p>
      </div>
    </aside>
    <article class="rounded border border-white/80 bg-white/92 p-8 shadow-soft sm:p-10">
      <div class="mb-8 border-b border-ink-200 pb-6">
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">{sectionLabel}</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink-950 sm:text-5xl">{entry.data.title}</h1>
        {
          entry.data.description && <p class="mt-4 max-w-3xl text-base leading-8 text-ink-600">{entry.data.description}</p>
        }
      </div>
      <div class="rich-content">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
