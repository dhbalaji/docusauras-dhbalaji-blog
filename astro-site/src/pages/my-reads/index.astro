---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { READS_CONFIG } from '../../lib/site';
import { formatDate, getEntryDate, getPublishedReads, getReadUrl, paginate, resolveReadImage } from '../../lib/content';

const allReads = await getPublishedReads();
const page = paginate(allReads, 1, READS_CONFIG.postsPerPage);
---

<BaseLayout title={READS_CONFIG.title} description={READS_CONFIG.description} path="/my-reads">
  <section class="rounded border border-white/80 bg-white/90 p-8 shadow-soft sm:p-10">
    <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Reading Practice</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink-950 sm:text-5xl">{READS_CONFIG.title}</h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-ink-600">{READS_CONFIG.description}</p>
    <p class="mt-8 text-sm font-semibold uppercase tracking-[0.2em] text-ink-500">Recent posts</p>
  </section>

  <section class="mt-8 grid gap-6 md:grid-cols-2">
    {
      page.items.map((read) => (
        <PostCard
          title={read.data.title}
          href={getReadUrl(read)}
          description={read.data.description}
          date={formatDate(getEntryDate(read))}
          image={resolveReadImage(read)}
        />
      ))
    }
  </section>

  <nav class="mt-10 flex items-center justify-between gap-4" aria-label="Pagination">
    <span class="text-sm text-ink-500">Page {page.page}</span>
    {
      page.hasNext ? (
        <a
          class="inline-flex items-center justify-center rounded bg-ink-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          href={`/my-reads/page/${page.nextPage}`}
        >
          Older posts
        </a>
      ) : <span />
    }
  </nav>
</BaseLayout>
