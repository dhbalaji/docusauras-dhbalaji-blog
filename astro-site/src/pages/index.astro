---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DETAILED_RESUME_URL, ONE_PAGE_RESUME_URL } from '../lib/site';

const whoami = `{
  "name": "Balaji",
  "designation": "Lead Frontend Engineer",
  "email": "balaji@dhbalaji.dev",
  "employer": "Sabre Corporation",
  "experience": "10+ years",
  "location": "Bangalore, India",
  "skills": [
    "Frontend architecture and system design",
    "Enterprise React application development",
    "Design systems and component libraries",
    "AI-powered frontend development and MCP servers",
    "Cross-functional technical leadership",
    "Design-to-code automation and developer tooling"
  ],
  "tagline": "Clarity in Code. Scale with Confidence."
}`;

const portfolioLinks = [
  { href: '/docs/experience/portfolio', label: 'Portfolio Overview' },
  { href: '/docs/experience/portfolio/online-presence', label: 'Online Presence' },
  { href: '/docs/experience/portfolio/side-projects', label: 'Pursuits' },
  { href: '/docs/experience/portfolio/soft-skills', label: 'Soft Skills' },
];
---

<BaseLayout title="Home" description="Description will go into a meta tag in <head />" path="/">
  <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
    <div class="rounded border border-white/80 bg-white/90 p-8 shadow-soft sm:p-10 lg:p-12">
      <div class="animate-fade-up inline-flex items-center gap-2 rounded border border-brand-200 bg-brand-50 px-4 py-2 text-xs font-bold uppercase tracking-[0.24em] text-brand-800">
        Principal Frontend Engineer Mindset
      </div>
      <h1 class="animate-fade-up-delay-1 mt-6 max-w-3xl font-display text-5xl font-semibold tracking-tight text-ink-950 sm:text-6xl">
        Hi, I&apos;m Balaji
      </h1>
      <p class="animate-fade-up-delay-1 mt-4 max-w-2xl text-xl font-medium text-ink-700 sm:text-2xl">
        Simple UI, Intelligent Frontend.
      </p>
      <p class="animate-fade-up-delay-2 mt-6 max-w-2xl text-base leading-8 text-ink-600 sm:text-lg">
        I design frontend systems that feel calm to users, predictable to teams, and resilient at enterprise scale.
        The focus is always the same: clear architecture, accessible interfaces, and fast-moving delivery without
        compromising quality.
      </p>
      <div class="animate-fade-up-delay-2 mt-8 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded bg-ink-950 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          href="/docs/experience/portfolio"
        >
          Portfolio
        </a>
        <a
          class="inline-flex items-center justify-center rounded border border-ink-300 bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:border-brand-300 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          href="/blog"
        >
          Read Articles
        </a>
      </div>
    </div>
    <aside class="surface-grid animate-float rounded border border-white/80 bg-white/80 p-6 shadow-soft sm:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.24em] text-ink-500">What I optimize for</p>
      <dl class="mt-6 grid gap-6 sm:grid-cols-3 lg:grid-cols-1">
        <div>
          <dt class="text-sm font-semibold text-ink-500">Architecture</dt>
          <dd class="mt-2 text-2xl font-bold text-ink-950">Scalable UI systems</dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-ink-500">Leadership</dt>
          <dd class="mt-2 text-2xl font-bold text-ink-950">Clear engineering direction</dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-ink-500">Delivery</dt>
          <dd class="mt-2 text-2xl font-bold text-ink-950">Fast, accessible outcomes</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="mt-8 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="rounded border border-white/80 bg-white/90 p-8 shadow-soft">
      <div class="overflow-hidden rounded bg-sand-100">
        <img
          src="/img/dhbalaji.jpg"
          alt="dhbalaji"
          class="aspect-[4/5] w-full object-cover object-top transition duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="mt-6 space-y-5 text-base leading-8 text-ink-600">
        <p>
          Balaji is a Lead Frontend Engineer at Sabre Travel Technologies, building scalable enterprise products and
          AI-enabled user interface design systems. A Toastmasters leader and lifelong tech nerd, he brings clarity,
          discipline, and maintainability to every system he designs.
        </p>
        <p>
          If you need proven frontend leadership, <a href="mailto:balaji@dhbalaji.dev">Email me!</a>
        </p>
      </div>
      <a
        class="mt-8 inline-flex items-center justify-center rounded bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
        href={DETAILED_RESUME_URL}
      >
        Descriptive Resume
      </a>
    </div>

    <div class="rounded border border-white/80 bg-ink-950 p-8 text-white shadow-soft">
      <div class="flex items-center justify-between gap-4">
        <h2 class="font-display text-3xl font-semibold tracking-tight"><code>whoami</code></h2>
        <span class="rounded border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-brand-100">
          Runtime identity
        </span>
      </div>
      <pre class="mt-6 overflow-x-auto rounded border border-white/10 bg-[#11192e] p-6 text-sm leading-7 text-sand-100"><code>{whoami}</code></pre>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-brand-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          href={ONE_PAGE_RESUME_URL}
        >
          One Page Resume
        </a>
        <a
          class="inline-flex items-center justify-center rounded border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          href="/docs/contact"
        >
          Contact
        </a>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <div id="portfolio" class="rounded border border-white/80 bg-white/90 p-8 shadow-soft">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Practice</p>
          <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink-950">Portfolio</h2>
        </div>
        <span class="rounded bg-sand-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-ink-600">
          10+ years
        </span>
      </div>
      <div class="mt-6 space-y-5 text-base leading-8 text-ink-600">
        <p>
          Balaji is a Lead Frontend Engineer with 10+ years of experience building scalable, high-performance, and
          secure web applications for enterprise platforms. He specializes in frontend architecture, system design, and
          modern JavaScript frameworks, with deep expertise in React, component libraries, design systems, and
          cloud-integrated UI solutions.
        </p>
        <p>
          At Sabre Travel Technologies, he plays a key role in delivering AI-powered products and enterprise UI
          platforms. As a founding member of the CRO AI product and the Spark design system, he has led end-to-end
          frontend development, from technical planning and framework selection to implementation, testing, and
          large-scale deployment.
        </p>
        <p>
          Beyond individual products, Balaji has led enterprise-wide initiatives such as portfolio rebranding, working
          within boundaries of Non Disclosure Agreements (NDA) and large-scale UI migrations.
        </p>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {portfolioLinks.map((item) => (
          <a
            class="inline-flex items-center justify-center rounded border border-ink-300 bg-white px-5 py-3 text-sm font-semibold text-ink-950 transition hover:border-brand-300 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div class="rounded border border-white/80 bg-white/90 p-8 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Signal</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink-950">
        AI-Powered Audio Summary of recent article
      </h2>
      <p class="mt-4 text-base leading-8 text-ink-600">
        A compact example of content presentation that stays accessible and lightweight while extending the written
        post experience.
      </p>
      <div class="mt-6 overflow-hidden rounded border border-ink-200 bg-sand-50 p-3">
        <iframe
          title="The Art of Felicitation: A Toastmasters Tale"
          allowtransparency="true"
          height="300"
          width="100%"
          style="border:none; min-width:min(100%, 430px); height:175px;"
          scrolling="no"
          data-name="pb-iframe-player"
          src="https://www.podbean.com/player-v2/?from=embed&i=6aki4-193504b-pb&square=1&share=1&download=1&fonts=Arial&skin=1&font-color=auto&rtl=0&logo_link=episode_page&btn-skin=3ab278&size=300"
          loading="lazy"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <section
    id="contact"
    class="mt-8 rounded border border-white/80 bg-[linear-gradient(135deg,rgba(15,23,42,0.98),rgba(8,47,73,0.96))] p-8 text-white shadow-soft sm:p-10"
  >
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-100">Contact me</p>
        <h2 class="mt-3 font-display text-4xl font-semibold tracking-tight">Contact me</h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-sand-100">
          If you need reliable frontend leadership, let&apos;s talk. I enjoy turning ambiguous product direction into
          durable interfaces, well-structured systems, and teams that can move faster with confidence.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-brand-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          href="mailto:balaji@dhbalaji.dev"
        >
          Email
        </a>
        <a
          class="inline-flex items-center justify-center rounded border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          href="https://www.linkedin.com/in/dhbalaji/"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
