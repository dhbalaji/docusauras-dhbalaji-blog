---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocsPages, getDocPageUrl } from '../../lib/content';

export async function getStaticPaths() {
  const pages = await getDocsPages();
  return pages.map((entry) => ({
    params: {
      slug: getDocPageUrl(entry).replace(/^\/docs\/?/, ''),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const routeSegments = entry.data.route.replace(/^\/docs\/?/, '').split('/').filter(Boolean);
const sectionLabel = routeSegments[0]?.replace(/-/g, ' ') ?? 'Docs';
const subSectionLabel = routeSegments.slice(1).join(' / ');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  path={entry.data.route}
  image={entry.data.image}
  keywords={entry.data.keywords ?? []}
>
  <section class="grid gap-8 lg:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="rounded border border-white/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.9),rgba(245,248,252,0.96))] p-6 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Documentation</p>
      <p class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink-950">{sectionLabel}</p>
      {
        subSectionLabel && <p class="mt-2 text-sm leading-7 text-ink-600">{subSectionLabel}</p>
      }
      <div class="mt-6 space-y-4 border-t border-ink-200 pt-4 text-sm text-ink-600">
        <p>
          Portfolio and reference pages are presented in a sharper editorial layout to improve scanning and keep long
          content readable.
        </p>
        <p class="font-mono text-xs text-ink-500">{entry.data.route}</p>
      </div>
    </aside>
    <article class="rounded border border-white/80 bg-white/95 p-8 shadow-soft sm:p-10">
      <div class="mb-8 border-b border-ink-200 pb-6">
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">Docs</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink-950 sm:text-5xl">{entry.data.title}</h1>
        {
          entry.data.description && <p class="mt-4 max-w-3xl text-base leading-8 text-ink-600">{entry.data.description}</p>
        }
      </div>
      <div class="rich-content">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
