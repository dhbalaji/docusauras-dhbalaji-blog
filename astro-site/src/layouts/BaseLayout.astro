---
import SeoHead from '../components/SeoHead.astro';
import { NAV_LINKS, SITE_TITLE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  path?: string;
  image?: string;
  publishedTime?: string;
  keywords?: string[];
}

const { title, description, path, image, publishedTime, keywords = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      path={path}
      image={image}
      publishedTime={publishedTime}
      keywords={keywords}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/img/favicon.png" />
    <link rel="alternate" type="application/rss+xml" href="/blog/rss.xml" title="dhbalaji.dev feed RSS Feed" />
    <link
      rel="alternate"
      type="application/rss+xml"
      href="/my-reads/rss.xml"
      title="dhbalaji, lead design technologist at Sabre RSS Feed"
    />
    <link
      rel="stylesheet"
      href="https://www.gstatic.com/dialogflow-console/fast/df-messenger/prod/v1/themes/df-messenger-default.css"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VGQ399LJC8"></script>
    <script async src="https://www.gstatic.com/dialogflow-console/fast/df-messenger/prod/v1/df-messenger.js"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VGQ399LJC8', {});
    </script>
  </head>
  <body class="selection:bg-brand-200 selection:text-ink-950">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-ink-950"
    >
      Skip to content
    </a>
    <div class="relative min-h-screen">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[36rem] bg-[radial-gradient(circle_at_top,_rgba(125,211,252,0.28),_transparent_48%),radial-gradient(circle_at_right,_rgba(45,212,191,0.14),_transparent_28%)]"></div>
      <header class="sticky top-0 z-40 border-b border-white/60 bg-white/80 backdrop-blur-xl">
        <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6 px-4 py-4 sm:px-6 lg:px-8">
          <a
            class="rounded px-3 py-2 text-sm font-extrabold tracking-[0.24em] text-ink-950 transition hover:bg-white hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
            href="/"
          >
            {SITE_TITLE}
          </a>
          <nav class="flex flex-wrap items-center justify-end gap-2 sm:gap-3" aria-label="Main">
            {NAV_LINKS.map((item) => (
              <a
                class:list={[
                  'rounded px-4 py-2 text-sm font-semibold transition duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500',
                  currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                    ? 'bg-ink-950 text-white shadow-soft'
                    : 'text-ink-700 hover:bg-white hover:text-ink-950',
                ]}
                href={item.href}
                aria-current={currentPath === item.href || currentPath.startsWith(`${item.href}/`) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>
      <main id="content" class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-14">
        <slot />
      </main>
      <footer class="border-t border-ink-200/70 bg-white/75 backdrop-blur">
        <div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
          <div class="grid gap-8 md:grid-cols-[1.3fr_1fr_1fr_1fr]">
            <div class="space-y-3">
              <p class="text-xs font-bold uppercase tracking-[0.28em] text-brand-700">Engineering Presence</p>
              <p class="max-w-sm text-sm leading-7 text-ink-600">
                Thoughtful frontend architecture, sharp execution, and communication built for products that need to
                scale cleanly.
              </p>
            </div>
            <div class="space-y-3">
              <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-ink-500">Technical</h2>
              <div class="flex flex-col gap-2 text-sm text-ink-700">
                <a class="transition hover:text-brand-700" href="/docs/experience/portfolio">Portfolio</a>
              </div>
            </div>
            <div class="space-y-3">
              <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-ink-500">Non Technical</h2>
              <div class="flex flex-col gap-2 text-sm text-ink-700">
                <a class="transition hover:text-brand-700" href="/blog">Articles</a>
                <a class="transition hover:text-brand-700" href="/pr-corner">PR Corner</a>
              </div>
            </div>
            <div class="space-y-3">
              <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-ink-500">Contact me</h2>
              <div class="flex flex-col gap-2 text-sm text-ink-700">
                <a class="transition hover:text-brand-700" href="mailto:balaji@dhbalaji.dev">Email</a>
                <a class="transition hover:text-brand-700" href="https://www.linkedin.com/in/dhbalaji/">LinkedIn</a>
                <a class="transition hover:text-brand-700" href="https://www.github.com/dhbalaji/">Github</a>
              </div>
            </div>
          </div>
          <div class="mt-10 flex flex-col gap-3 border-t border-ink-200/70 pt-6 text-sm text-ink-500 sm:flex-row sm:items-center sm:justify-between">
            <small>Copyright (c) {new Date().getFullYear()} dhbalaji.dev</small>
            <p>Built for clarity, accessibility, and durable frontend craft.</p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
