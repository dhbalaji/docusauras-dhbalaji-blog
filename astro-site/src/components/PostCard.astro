---
interface Props {
  title: string;
  href: string;
  description?: string;
  date?: string;
  image?: string;
}

const { title, href, description = '', date = '', image } = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded border border-white/70 bg-white/90 shadow-soft transition duration-300 hover:-translate-y-1 hover:shadow-lg">
  {
    image && (
      <a href={href} class="overflow-hidden">
        <img
          src={image}
          alt={title}
          loading="lazy"
          class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col gap-4 p-6">
    {
      date && <div class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">{date}</div>
    }
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink-950">
      <a class="transition hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" href={href}>{title}</a>
    </h2>
    {
      description && <p class="text-sm leading-7 text-ink-600">{description}</p>
    }
    <div class="mt-auto pt-2">
      <a class="inline-flex items-center gap-2 text-sm font-semibold text-ink-950 transition hover:text-brand-700" href={href}>
        Read more
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
